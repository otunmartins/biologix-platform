# Example environment configuration
# Copy this to .env and add your actual values
#   cp .env.example .env

# Semantic Scholar API Key (optional; higher rate limits)
# https://www.semanticscholar.org/api-gallery
SEMANTIC_SCHOLAR_API_KEY=your_api_key_here

# Ollama (local LLM for literature mining)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# PaperQA2 / OpenAI (optional; or use Ollama for embeddings)
OPENAI_API_KEY=sk-...
