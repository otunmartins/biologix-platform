# Biologix AI — environment variables
# Copy this file to .env and fill in your keys:
#
#   cp .env.example .env
#
# .env is gitignored. Never commit your real keys.

# ── LLM provider (pick ONE) ───────────────────────────────────────────────────
# Anthropic Claude (recommended)
ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# OpenRouter (access multiple providers with one key)
# OPENROUTER_API_KEY=

# ── Optional: Semantic Scholar / Allen AI ─────────────────────────────────────
# Required only for the remote 'asta' MCP (literature search enhancement).
# Leave blank to use the built-in literature mining tools.
ASTA_API_KEY=

# ── Docker build options ──────────────────────────────────────────────────────
# Set SLIM=1 to build a smaller image that downloads AiZynth models and the
# precursor database on first run instead of baking them in.
# SLIM=0

# ── Docker runtime CPU (optional) ─────────────────────────────────────────────
# scripts/docker_run.sh and scripts/docker_compose_run.sh set --cpus to 75% of
# host logical CPUs by default (optional macOS headroom). The image entrypoint
# always auto-detects container CPUs for OpenMM regardless of --cpus.
# Override host quota percent: DOCKER_CPU_PCT=100
# Override absolute quota: DOCKER_CPU_LIMIT=4
# In-container OpenMM fraction: BIOLOGIX_AI_EVAL_CPU_FRACTION=0.75
