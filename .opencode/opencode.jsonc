{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "biologics-delivery-discovery",
  // Agents: any MCP timeout (any reason) → bash CLI per .opencode/MCP_CLI_FALLBACK.md (no MCP retry).
  "experimental": {
    // Stdio MCP: server rejects parallel calls (MCP_BUSY); align with candidate timeout stack.
    "mcp_timeout": 960000
  },
  "mcp": {
    "biologix-ai": {
      "type": "local",
      "command": ["bash", "scripts/run_mcp_server.sh"],
      "environment": {
        "PAPER_DIRECTORY": "./papers",
        "RETRO_LLM_BACKEND": "skip",
        "BIOLOGIX_AI_AIZYNTH_CONFIG": "./data/aizynthfinder/config.yml"
      },
      "enabled": true
    },
    "asta": {
      "type": "remote",
      "url": "https://asta-tools.allen.ai/mcp/v1",
      // Set enabled to true here OR set ASTA_API_KEY in your .env to activate.
      // Disabled by default so the container starts cleanly without the key.
      "enabled": false,
      "oauth": false,
      "headers": {
        "x-api-key": "{env:ASTA_API_KEY}"
      }
    }
  }
}
