{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "biologics-delivery-discovery",
  // Disable per-step git snapshots: old apt git (2.25.x) rejects `git add --sparse`
  // and indexing /app + submodules stalls the agent loop (OpenCode #21302).
  "snapshot": false,
  "autoupdate": false,
  // Agents: any MCP timeout → session latches to CLI-only per .opencode/MCP_CLI_FALLBACK.md (no MCP after).
  "experimental": {
    // Whole MCP tool call budget (ms); aligned with BIOLOGIX_AI_MCP_TIMEOUT_MS / candidate cap.
    "mcp_timeout": 600000
  },
  "mcp": {
    "biologix-ai": {
      "type": "local",
      "command": ["bash", "scripts/run_mcp_server.sh"],
      "cwd": ".",
      // Server setup / catalog fetch timeout (ms); tool calls use experimental.mcp_timeout above.
      "timeout": 60000,
      "environment": {
        "PAPER_DIRECTORY": "./papers",
        "RETRO_LLM_BACKEND": "skip",
        "BIOLOGIX_AI_AIZYNTH_CONFIG": "./data/aizynthfinder/config.yml",
        "PYTHONUNBUFFERED": "1",
        "PYTHONIOENCODING": "utf-8"
      },
      "enabled": true
    },
    "asta": {
      "type": "remote",
      "url": "https://asta-tools.allen.ai/mcp/v1",
      // Set enabled to true here OR set ASTA_API_KEY in your .env to activate.
      // Disabled by default so the container starts cleanly without the key.
      "enabled": false,
      "oauth": false,
      "headers": {
        "x-api-key": "{env:ASTA_API_KEY}"
      }
    }
  }
}
