{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "biologics-delivery-discovery",
  "experimental": {
    "mcp_timeout": 2147483647
  },
  "mcp": {
    "insulin-ai": {
      "type": "local",
      "command": ["bash", "scripts/run_mcp_server.sh"],
      "environment": {
        "PAPER_DIRECTORY": "./papers"
      },
      "enabled": true
    },
    "asta": {
      "type": "remote",
      "url": "https://asta-tools.allen.ai/mcp/v1",
      "enabled": true,
      "oauth": false,
      "headers": {
        "x-api-key": "{env:ASTA_API_KEY}"
      }
    }
  }
}
