#!/usr/bin/env bash
# Biologix AI Platform - Install
#
# 1) OpenCode + biologix-ai launcher
# 2) Python deps: conda env biologix-ai-sim (chunked conda + pip — low OOM risk) OR pip-only
# 3) Retro/admet submodules + AiZynthFinder models (default)
# 4) verify_install.sh (fail-fast)
#
# Usage: ./install [--no-path] [--pip-only] [--conda-yml] [--skip-submodules] [--skip-aizynth-models]

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_NAME="biologix-ai"
YML="$SCRIPT_DIR/environment-simulation.yml"
export BIOLOGIX_AI_CONDA_ENV="${BIOLOGIX_AI_CONDA_ENV:-biologix-ai-sim}"

# shellcheck source=scripts/install_lib.sh
source "$SCRIPT_DIR/scripts/install_lib.sh"

usage() {
  cat <<EOF
Biologix AI Platform – Install

Usage: ./install [options]

  --no-path      Don't add ~/.local/bin to PATH in shell config
  --pip-only     Skip conda; use pip install -e ".[simulation]" (weaker OpenMM setup)
  --conda-yml    One-shot conda env create/update from environment-simulation.yml
                 (needs more RAM; default is chunked install via scripts/install_biologix_ai_sim_lowmem.sh)
  --skip-submodules   Skip RetroSynthesisAgent, AiZynthFinder package, ADMET-AI (not recommended)
  --skip-aizynth-models   Skip ~800MB AiZynthFinder model download (retro still works; monomer enrichment limited)

Installs:
  - OpenCode (https://opencode.ai/install)
  - Python environment: chunked conda-forge + pip (default), or --conda-yml, or --pip-only
  - Git submodules + retro/admet stack (default; use --skip-submodules to omit)
  - AiZynthFinder public models (default; use --skip-aizynth-models to omit)
  - Verification gate (scripts/verify_install.sh)

Run from the repo root.
EOF
}

no_modify_path=false
pip_only=false
conda_yml=false
skip_submodules=false
skip_aizynth_models=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    --no-path) no_modify_path=true; shift ;;
    --pip-only) pip_only=true; shift ;;
    --conda-yml) conda_yml=true; shift ;;
    --skip-submodules) skip_submodules=true; shift ;;
    --skip-aizynth-models) skip_aizynth_models=true; shift ;;
    *) echo -e "${RED}Unknown option: $1${NC}"; usage; exit 1 ;;
  esac
done

INSTALL_DIR="${OPENCODE_INSTALL_DIR:-${XDG_BIN_DIR:-$HOME/.local/bin}}"
mkdir -p "$INSTALL_DIR"

echo -e "${GREEN}Biologix AI Platform – Install${NC}"
echo ""

# --- OpenCode ---
OPENCODE_BIN_DIR="${HOME}/.opencode/bin"
export PATH="${OPENCODE_BIN_DIR}:$PATH"
if [[ ! -x "${OPENCODE_BIN_DIR}/opencode" ]] && ! command -v opencode >/dev/null 2>&1; then
  echo "Installing OpenCode..."
  curl -fsSL https://opencode.ai/install | bash || true
  export PATH="${OPENCODE_BIN_DIR}:$PATH"
fi
if [[ -x "${OPENCODE_BIN_DIR}/opencode" ]]; then
  echo "OpenCode: ${OPENCODE_BIN_DIR}/opencode"
elif command -v opencode >/dev/null 2>&1; then
  echo "OpenCode: $(command -v opencode)"
else
  echo -e "${RED}OpenCode not found.${NC} curl -fsSL https://opencode.ai/install | bash"
  exit 1
fi

# --- Python / MCP dependencies ---
echo ""
echo -e "${GREEN}Python dependencies (MCP server + simulation)${NC}"

install_conda_env() {
  if ! command -v conda &>/dev/null && ! command -v mamba &>/dev/null; then
    return 1
  fi

  if [[ "$conda_yml" != "true" ]]; then
    echo -e "${YELLOW}Installing conda env ${ENV_NAME} (chunked conda-forge + pip)...${NC}"
    bash "$SCRIPT_DIR/scripts/install_biologix_ai_sim_lowmem.sh"
    echo -e "${GREEN}Conda env ${ENV_NAME} ready${NC}"
    return 0
  fi

  if conda config --show channels 2>/dev/null | grep -qi omnia; then
    echo -e "${RED}Your conda channel list includes \"omnia\".${NC}"
    echo -e "${YELLOW}Run: bash scripts/fix_conda_channels_for_biologix_ai.sh${NC}"
    echo ""
  fi
  refresh_conda_prefix_path
  remove_broken_micromamba
  if micromamba_usable && [[ -n "${CONDA_PREFIX_PATH}" ]]; then
    echo -e "${YELLOW}Updating ${ENV_NAME} via micromamba (libmamba 2.x)...${NC}"
    if env_exists; then
      micromamba env update -p "${CONDA_PREFIX_PATH}" -f "$YML" --prune -y
    else
      micromamba env create -p "${CONDA_PREFIX_PATH}" -f "$YML" -y
    fi
  elif command -v mamba &>/dev/null; then
    echo -e "${YELLOW}Updating ${ENV_NAME} via mamba...${NC}"
    if env_exists; then
      mamba env update -f "$YML" --prune -y
    else
      mamba env create -f "$YML" -y
    fi
  else
    local solver_args=(--solver classic)
    if env_exists; then
      echo -e "${YELLOW}Conda env ${ENV_NAME} exists — updating from environment-simulation.yml (classic solver)...${NC}"
      conda env update -f "$YML" --prune "${solver_args[@]}"
    else
      echo "Creating conda env ${ENV_NAME} from environment-simulation.yml (classic solver)..."
      conda env create -f "$YML" "${solver_args[@]}"
    fi
  fi
  refresh_conda_prefix_path
  verify_conda_stack
  echo -e "${GREEN}Conda env ${ENV_NAME} ready${NC}"
  return 0
}

install_pip() {
  echo "pip: requirements.txt + editable (no conda)..."
  cd "$SCRIPT_DIR"
  python3 -m pip install -U pip setuptools wheel
  python3 -m pip install -r requirements.txt
  python3 -m pip install -e ".[simulation,paperqa,retro,admet,dev]" 2>/dev/null \
    || python3 -m pip install -e ".[simulation,retro,admet,dev]"
  echo -e "${YELLOW}Warning: OpenMM, RDKit, pdbfixer, Packmol, and OpenFF Toolkit are NOT installed by pip-only.${NC}"
  echo -e "${YELLOW}  Use ./install (chunked conda) for the full stack.${NC}"
}

if [[ "$pip_only" == "true" ]] || { ! command -v mamba &>/dev/null && ! command -v conda &>/dev/null; }; then
  install_pip
else
  if ! install_conda_env; then
    install_pip
  fi
fi

# Conda-only verify (lowmem script verifies inline; conda-yml path verifies in install_conda_env)
if [[ "$pip_only" != "true" ]] && command -v conda &>/dev/null && env_exists; then
  VERIFY_ARGS=(--conda-only)
  bash "$SCRIPT_DIR/scripts/verify_install.sh" "${VERIFY_ARGS[@]}"
fi

# --- Submodules: RetroSyn, AiZynthFinder package, ADMET-AI ---
if [[ "$skip_submodules" != "true" ]]; then
  echo ""
  echo -e "${GREEN}Retrosynthesis + ADMET submodules${NC}"
  bash "$SCRIPT_DIR/scripts/install_submodules.sh"
else
  echo -e "${YELLOW}Skipped submodules (--skip-submodules)${NC}"
fi

# --- AiZynthFinder model weights (~800MB, one-time) ---
if [[ "$skip_aizynth_models" != "true" ]] && [[ "$skip_submodules" != "true" ]]; then
  echo ""
  echo -e "${GREEN}AiZynthFinder models${NC}"
  bash "$SCRIPT_DIR/scripts/setup_aizynthfinder.sh"
elif [[ "$skip_aizynth_models" == "true" ]]; then
  echo -e "${YELLOW}Skipped AiZynthFinder models (--skip-aizynth-models)${NC}"
fi

# --- Full verification ---
echo ""
echo -e "${GREEN}Verifying install${NC}"
VERIFY_FULL=( )
[[ "$skip_submodules" == "true" ]] && VERIFY_FULL+=(--skip-submodules)
[[ "$skip_aizynth_models" == "true" ]] && VERIFY_FULL+=(--skip-aizynth-models)
if [[ "$pip_only" == "true" ]]; then
  echo -e "${YELLOW}Skipping full verify (--pip-only); OpenMM stack not expected.${NC}"
else
  bash "$SCRIPT_DIR/scripts/verify_install.sh" ${VERIFY_FULL[@]+"${VERIFY_FULL[@]}"}
fi

# --- Launcher ---
write_launcher() {
  local dest="$1"
  cat > "$dest" <<LAUNCHER_SCRIPT
#!/usr/bin/env bash
BIOLOGIX_AI_ROOT="$SCRIPT_DIR"
PROJECT="\${1:-\$BIOLOGIX_AI_ROOT}"
cd "\$BIOLOGIX_AI_ROOT"
export PATH="\${HOME}/.opencode/bin:\$PATH"
if [[ -x "\${HOME}/.opencode/bin/opencode" ]]; then
  exec "\${HOME}/.opencode/bin/opencode" "\$PROJECT"
fi
command -v opencode >/dev/null 2>&1 && exec opencode "\$PROJECT"
echo "opencode not found" >&2
exit 127
LAUNCHER_SCRIPT
  chmod +x "$dest"
}

LAUNCHER="$INSTALL_DIR/$BIN_NAME"
write_launcher "$LAUNCHER"

echo ""
echo -e "${GREEN}Install complete${NC}"
echo "  Launcher:  $LAUNCHER"
echo "  Run:       $BIN_NAME"
echo "  Conda env: ${ENV_NAME}"
echo "  MCP:       bash scripts/run_mcp_server.sh (auto-started by OpenCode)"
if [[ "$skip_submodules" != "true" ]]; then
  echo "  Retro/ADMET: installed"
fi
if [[ "$skip_aizynth_models" != "true" ]] && [[ "$skip_submodules" != "true" ]]; then
  echo "  AiZynth models: data/aizynthfinder/"
fi
echo ""

if [[ "$no_modify_path" != "true" ]] && [[ ":$PATH:" != *":$INSTALL_DIR:"* ]]; then
  for rc in .zshrc .bashrc .bash_profile .profile; do
    if [[ -f "$HOME/$rc" ]]; then
      if ! grep -q "Biologix AI Platform" "$HOME/$rc" 2>/dev/null; then
        echo "" >> "$HOME/$rc"
        echo "# Biologix AI Platform" >> "$HOME/$rc"
        echo "export PATH=\"$INSTALL_DIR:\$PATH\"" >> "$HOME/$rc"
        echo "  Added $INSTALL_DIR to $HOME/$rc"
        break
      fi
    fi
  done
fi
